# ─── Resend (email delivery) ─────────────────────────────
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Create an API key at https://resend.com/api-keys
# 3. Paste it below, then rename this file to .env.local
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: once you verify litcreativedesigns.com with Resend,
# update the 'from' address in app/api/contact/route.ts to:
# 'Lit Creative Designs <noreply@litcreativedesigns.com>'
